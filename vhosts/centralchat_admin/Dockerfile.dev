# Development Dockerfile — Bun + TanStack Start dev server com hot-reload.
# Produção: usar Dockerfile (build estático + preview).

FROM docker.io/oven/bun:1

WORKDIR /app

COPY package.json bun.lock ./
RUN bun install

# O código fonte é montado via volume no docker-compose.dev.yml.
# Só copiamos o mínimo para o bun install funcionar.

EXPOSE 5175

CMD ["bun", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5175"]
