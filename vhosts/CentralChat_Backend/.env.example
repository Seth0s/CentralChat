# CentralChat — Environment Variables
# =============================================================================
# Só o essencial. Secrets (API keys, passwords) são geridos pela UI admin,
# não por variáveis de ambiente.
#
# Docker: inject via env_file. Local: cp .env.example .env
# Convenções: (required) = obrigatório, [default: X] = omitir usa X

# ═══════════════════════════════════════════════════════════════════════════
# 1. REDE
# ═══════════════════════════════════════════════════════════════════════════

API_HOST=0.0.0.0                            # [default: 127.0.0.1]
API_PORT=8004                               # [default: 8004]

# ═══════════════════════════════════════════════════════════════════════════
# 2. AMBIENTE
# ═══════════════════════════════════════════════════════════════════════════

CENTRAL_APP_ENV=development                 # [default: development] development | production
CENTRAL_ROOT=~/.central                     # [default: ~/.central] Docker: /central

# ═══════════════════════════════════════════════════════════════════════════
# 3. DATABASE (PostgreSQL + pgvector)
# ═══════════════════════════════════════════════════════════════════════════

MEMORY_DB_URL=postgresql://user:***@host:5432/dbname  # (required) TEAM mode
MEMORY_ENABLED=1                            # [default: 1] 0 = sem PG (SOLO local)

# ═══════════════════════════════════════════════════════════════════════════
# 4. AUTH — JWT (TEAM mode)
# ═══════════════════════════════════════════════════════════════════════════

CENTRAL_JWT_MODE=required                   # [default: off] off | required
CENTRAL_JWT_SECRET=***                      # (required se mode != off) HS256 ≥32 chars

# ═══════════════════════════════════════════════════════════════════════════
# 5. CORS
# ═══════════════════════════════════════════════════════════════════════════

# CENTRAL_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ═══════════════════════════════════════════════════════════════════════════
# NOTAS
# ═══════════════════════════════════════════════════════════════════════════
#
# API Keys dos providers (OpenRouter, Anthropic, OpenAI, DeepSeek, Groq, Ollama)
#   → Configuráveis na UI Admin, não no .env.
#
# Rate limits, quotas, feature flags
#   → Configuráveis por tenant na UI Admin (ContextPolicy).
#
# OIDC, bootstrap admin, login rate limits
#   → Enterprise only. Documentação separada em docs/OIDC.md.
#
# Secrets (JWT secret, DB password)
#   → Em produção, usar vault ou secrets manager. .env é só para dev local.
