# CentralChat Web — Frontend (TanStack Start)
#
#   cp .env.example .env
#
# Variáveis de build-time (VITE_*) e runtime.

# ── App ──
VITE_APP_NAME=Central
VITE_APP_SURFACE=web

# ── Orchestrator ──
# Docker (compose): http://orchestrator:8004
# Local dev (fora do Docker): http://localhost:8004
VITE_ORCHESTRATOR_PROXY_TARGET=http://orchestrator:8004
